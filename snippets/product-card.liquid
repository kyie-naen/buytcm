{% unless product.tags contains 'b2b' %}
<div class="card position-relative productcard bg-card">
    {% form 'product', product %}
    <input type="hidden" name="id" value="{{ varian }}" />
    <input type="hidden" name="qty" value="1" />
    <div class="img-zoom card-body-top-border-radius">
        <img loading="lazy" class="img-fluid" src="{{ image | img_url: 'grande' }}" alt="{{title}}" srcset="{{ image | img_url: '320x320' }} 320w, {{ image | img_url: '480x480' }} 480w, {{ image | img_url: '800x800' }} 800w" sizes="(max-width: 320px) 280px, (max-width: 480px) 440px, 800px"/>
    </div>
    <div class="card-body px-1 py-3 d-flex justify-content-around">
        <div class="text-product mt-auto">
            <a href="{{url}}"><p class="card-product-name mb-0">{{title}}</p></a>
            <p class="card-text">{{price | money}}</p>
        </div>
        {% if customer == null %}
            <a href="{{routes.account_login_url}}" class="add-to-cart text-white">
                {% render 'icon-add-to-cart' %}
            </a>
        {% else %}
            <button type="submit" class="add-to-cart">
                {% render 'icon-add-to-cart' %}
            </button>  
        {% endif %} 
    </div>
    {% comment %} <a href="{{url}}" class="btn-quick">{{ 'general.all.quick-view' | t }}</a> {% endcomment %}
    {% comment %} <a href="#" onclick="getDataModal('{{title}}')" class="btn-quick" data-bs-toggle="modal" data-bs-target="#exampleModal">Quick View</a> {% endcomment %}
{% endform %}
</div>
{% endunless %}
<!-- Modal -->
<div class="modal fade" id="exampleModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                
            </div>
        </div>
    </div>
</div>